# Camera
CAMERA_RESOLUTION=3280x2464
CAMERA_FRAMERATE=20
CAPTURE_INTERVAL_SECONDS=60

# Motion detection
MOTION_SCORE_THRESHOLD=0.02
MOTION_RESIZE_WIDTH=320
MOTION_RESIZE_HEIGHT=180

# Detection
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45

# Recognition
EMBEDDING_THRESHOLD=0.7
MAX_INDIVIDUALS=50

# Database
DB_PATH=data/birdfeeder.db

# Flask
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=birdfeeder.log
