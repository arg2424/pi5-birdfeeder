# Camera
CAMERA_RESOLUTION=3280x2464
CAMERA_FRAMERATE=20
CAPTURE_INTERVAL_SECONDS=60

# Motion detection
MOTION_SCORE_THRESHOLD=0.02
MOTION_RESIZE_WIDTH=320
MOTION_RESIZE_HEIGHT=180
MOTION_SCORE_SMOOTHING=0.55
MOTION_ARM_CONSECUTIVE=2

# Detection
YOLO_CONFIDENCE=0.5
YOLO_IOU=0.45

# Recognition
EMBEDDING_THRESHOLD=0.7
MAX_INDIVIDUALS=50

# Event filtering and cleanup
EVENT_COOLDOWN_SECONDS=0
SAVE_BIRD_EVENTS_ONLY=false
EVENT_RETENTION_DAYS=14
MAINTENANCE_INTERVAL_SECONDS=900

# Event clips
EVENT_CLIP_ENABLED=true
EVENT_CLIP_POST_FRAMES=6
EVENT_CLIP_FRAME_INTERVAL_SECONDS=0.2
EVENT_CLIP_MAX_WIDTH=960

# Smart features
ALERT_WEBHOOK_URL=
ALERT_MIN_CONFIDENCE=0.78
ALERT_NEW_INDIVIDUALS_ONLY=false
DAILY_EXPORT_ENABLED=true

# Database
DB_PATH=data/birdfeeder.db

# Flask
FLASK_PORT=5000
FLASK_HOST=0.0.0.0
FLASK_DEBUG=False

# Logging
LOG_LEVEL=INFO
LOG_FILE=birdfeeder.log
